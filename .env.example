APP_NAME=request-api
APP_ENV=development
APP_PORT=8080
APP_READ_TIMEOUT=10s
APP_WRITE_TIMEOUT=15s
APP_SHUTDOWN_TIMEOUT=10s
APP_REQUEST_TIMEOUT=15s
APP_MAX_BODY_BYTES=52428800

DATABASE_URL=postgres://request_user:change-me@localhost:5432/request?sslmode=disable
DATABASE_MAX_OPEN_CONNS=15
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=30m

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=info
